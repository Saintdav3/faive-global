# ─────────────────────────────────────────
# Faive Global — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server port (defaults to 3000 if not set)
PORT=3000

# Frontend origin allowed by CORS
# In production, replace with your actual domain e.g. https://faiveglobal.ltd
CLIENT_ORIGIN=http://localhost:5500

# ── Nodemailer / SMTP ─────────────────────
# Works with Gmail, Zoho, Brevo, SendGrid SMTP, etc.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_app_password   ← generate at myaccount.google.com/apppasswords
#
# Brevo (free 300/day) example:
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your_brevo_login_email
#   SMTP_PASS=your_brevo_smtp_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password

# ── Email routing ─────────────────────────
# Where to deliver form submissions (your inbox)
TO_EMAIL=hello@faiveglobal.ltd

# The "From" address shown in emails (must match or be authorised by your SMTP provider)
FROM_EMAIL=Faive Global <noreply@faiveglobal.ltd>
